{
  "rewrites": [
    {
      "source": "/proxy",
      "destination": "/api/firmware"
    }
  ],
  "headers": [
    {
      "source": "/((?!amy-|amyboard-).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/(amyboard|amy)-(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
